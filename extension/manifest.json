{
  "manifest_version": 3,
  "name": "ghostmeet",
  "version": "0.3.0",
  "description": "AI meeting assistant — live captions and summaries from any browser tab",
  "permissions": ["tabCapture", "activeTab", "storage", "sidePanel", "offscreen", "microphone"],
  "host_permissions": ["http://*/*", "ws://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
