{
  "manifest_version": 3,
  "name": "attend capture",
  "version": "0.1.0",
  "description": "Capture active tab audio and stream to local attend backend",
  "permissions": ["tabCapture", "activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:8877/*", "ws://127.0.0.1:8877/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
